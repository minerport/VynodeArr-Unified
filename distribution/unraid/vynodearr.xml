<?xml version="1.0"?>
<Container version="2">
  <Name>VynodeArr</Name>
  <Repository>ghcr.io/minerport/vynodearr-unified:0.4.3</Repository>
  <Registry>https://github.com/minerport/VynodeArr-Unified/pkgs/container/vynodearr-unified</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/minerport/VynodeArr-Unified/issues</Support>
  <Project>https://github.com/minerport/VynodeArr-Unified</Project>
  <Overview>Experimental unified movie and television media manager. One dashboard supervises isolated movie and television engines. Uses its own appdata and port, so existing Radarr and Sonarr containers remain separate. Use unique download-client categories such as vynode-movies and vynode-tv.</Overview>
  <Category>MediaApp:Other</Category>
  <WebUI>http://[IP]:[PORT:8686]/</WebUI>
  <Icon>https://raw.githubusercontent.com/minerport/VynodeArr-Unified/main/assets/branding/VynodeArr.png</Icon>
  <ExtraParams>--user 99:100 --stop-timeout 60</ExtraParams>
  <PostArgs></PostArgs>
  <CPUset></CPUset>
  <DateInstalled>0</DateInstalled>
  <DonateText></DonateText>
  <DonateLink></DonateLink>
  <Requires>Experimental x86-64 image. Runs as Unraid nobody:users (99:100). Selected appdata, media, and download paths must be writable by that identity. Never map existing Radarr or Sonarr appdata into /config.</Requires>
  <Config Name="Web UI" Target="8686" Default="8686" Mode="tcp" Description="Unified VynodeArr dashboard port" Type="Port" Display="always" Required="true" Mask="false">8686</Config>
  <Config Name="Appdata" Target="/config" Default="/mnt/user/appdata/vynodearr" Mode="rw" Description="Persistent unified, movie, and television configuration" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/vynodearr</Config>
  <Config Name="Movies" Target="/movies" Default="/mnt/user/movies" Mode="rw" Description="Movie library" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/movies</Config>
  <Config Name="Television" Target="/tv" Default="/mnt/user/tv" Mode="rw" Description="Television library" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/tv</Config>
  <Config Name="Downloads" Target="/downloads" Default="/mnt/user/downloads" Mode="rw" Description="Shared download-client path" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/downloads</Config>
  <Config Name="Timezone" Target="TZ" Default="America/New_York" Mode="" Description="IANA timezone" Type="Variable" Display="always" Required="true" Mask="false">America/New_York</Config>
  <Config Name="Lifecycle Control Key" Target="VynodeArr__LifecycleApiKey" Default="" Mode="" Description="Long random secret required for remote start, stop, and shutdown controls" Type="Variable" Display="always" Required="true" Mask="true"></Config>
</Container>
