<?xml version="1.0"?>
<Container version="2">
  <Name>VynodeArr</Name>
  <Repository>ghcr.io/minerport/vynodearr-unified:latest</Repository>
  <Registry>https://github.com/minerport/VynodeArr-Unified/pkgs/container/vynodearr-unified</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/minerport/VynodeArr-Unified/issues</Support>
  <Project>https://github.com/minerport/VynodeArr-Unified</Project>
  <Overview>Unified movie and television management with installation-managed engines, one account, and one web interface.</Overview>
  <Description>VynodeArr provides one dashboard for movie and television library management while keeping engine databases and settings isolated. Choose separate media folders and one shared downloads folder.</Description>
  <Category>MediaApp:Video</Category>
  <WebUI>http://[IP]:[PORT:8686]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/minerport/VynodeArr-Unified/develop/templates/vynodearr.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/minerport/VynodeArr-Unified/develop/assets/branding/VynodeArr.png</Icon>
  <ExtraParams>--user 99:100 --stop-timeout 60</ExtraParams>
  <PostArgs/>
  <CPUset/>
  <DateInstalled>0</DateInstalled>
  <DonateText/>
  <DonateLink/>
  <Requires>x86-64 Unraid host with Docker. Appdata, media, and download paths must be writable by nobody:users (99:100).</Requires>
  <Config Name="Web UI" Target="8686" Default="8686" Mode="tcp" Description="VynodeArr web interface" Type="Port" Display="always" Required="true" Mask="false">8686</Config>
  <Config Name="Movies API" Target="7878" Default="7878" Mode="tcp" Description="Optional compatibility port for request applications such as Seerr" Type="Port" Display="advanced" Required="false" Mask="false">7878</Config>
  <Config Name="Television API" Target="8989" Default="8989" Mode="tcp" Description="Optional compatibility port for request applications such as Seerr" Type="Port" Display="advanced" Required="false" Mask="false">8989</Config>
  <Config Name="Appdata" Target="/config" Default="/mnt/user/appdata/vynodearr" Mode="rw" Description="Persistent VynodeArr and engine configuration" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/vynodearr</Config>
  <Config Name="Movies" Target="/movies" Default="/mnt/user/media/movies" Mode="rw" Description="Movie library" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/media/movies</Config>
  <Config Name="Television" Target="/tv" Default="/mnt/user/media/tv" Mode="rw" Description="Television library" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/media/tv</Config>
  <Config Name="Downloads" Target="/downloads" Default="/mnt/user/downloads" Mode="rw" Description="Shared download-client path" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/downloads</Config>
  <Config Name="Timezone" Target="TZ" Default="America/New_York" Mode="" Description="IANA timezone" Type="Variable" Display="always" Required="true" Mask="false">America/New_York</Config>
</Container>
