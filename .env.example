# Copy to .env. Never commit actual credentials.
VYNODENEW_DATA_MODE=engine
VYNODENEW_DATA_DIR=/data
VYNODENEW_SECURE_COOKIES=false
VYNODENEW_SYNC_INTERVAL_MS=300000
VYNODENEW_CACHE_MAX_ITEMS=5000
# Required only when the encrypted credential vault is used.
VYNODENEW_MASTER_KEY=replace-with-at-least-24-random-characters
# Or mount a stable secret file:
VYNODENEW_MASTER_KEY_FILE=

MOVIE_ENGINE_ENABLED=true
MOVIE_ENGINE_HOST=movie-engine
MOVIE_ENGINE_PORT=7878
MOVIE_ENGINE_HTTPS=false
MOVIE_ENGINE_URL_BASE=
MOVIE_ENGINE_API_CREDENTIAL=vynodenew-local-movie-key-2026
# Prefer a mounted secret file in production:
MOVIE_ENGINE_API_CREDENTIAL_FILE=
MOVIE_ENGINE_TIMEOUT_MS=8000
MOVIE_ENGINE_RETRIES=1
MOVIE_ENGINE_TLS_VERIFY=true
MOVIE_ENGINE_FIXTURE_FALLBACK=false

TV_ENGINE_ENABLED=true
TV_ENGINE_HOST=tv-engine
TV_ENGINE_PORT=8989
TV_ENGINE_HTTPS=false
TV_ENGINE_URL_BASE=
TV_ENGINE_API_CREDENTIAL=vynodenew-local-tv-key-2026
TV_ENGINE_API_CREDENTIAL_FILE=
TV_ENGINE_TIMEOUT_MS=8000
TV_ENGINE_RETRIES=1
TV_ENGINE_TLS_VERIFY=true
TV_ENGINE_FIXTURE_FALLBACK=false
